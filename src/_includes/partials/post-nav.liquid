{% if newerPost or olderPost %}
    <nav class="grid grid-cols-2 gap-6 pt-8 mt-20 text-base border-t border-gray-600">
        {% if newerPost %}
            <a href="{{ newerPost.url }}" class="group">
                <p class="mb-2 font-sans text-lg font-bold text-gray-200 group-hover:text-white">
                    <span class="group-hover:text-accent">&larr;</span>
                    {% if newerPost.data.title %}
                        {{ newerPost.data.title }}
                    {% else %}
                        Newer post
                    {% endif %}
                </p>
                <p class="mt-2 mb-2 font-sans text-sm text-gray-500">{{ newerPost.date | date: '%-d %b %Y' }}</p>
                {% if newerPost.data.summary %}
                    <p class="text-sm text-gray-400">{{ newerPost.data.summary | truncate: 100 }}</p>
                    {% elsif newerPost.data.title == nil %}
                    <p class="text-sm text-gray-400">{{ newerPost.content | strip_html | truncate: 100 }}</p>
                {% endif %}
            </a>
        {% else %}
            <span></span>
        {% endif %}
        {% if olderPost %}
            <a href="{{ olderPost.url }}" class="text-right group">
                <p class="mb-2 font-sans text-lg font-bold text-gray-200 group-hover:text-white">
                    {% if olderPost.data.title %}
                        {{ olderPost.data.title }}
                    {% else %}
                        Older post
                    {% endif %}
                    <span class="group-hover:text-accent">&rarr;</span>
                </p>
                <p class="mt-2 mb-2 font-sans text-sm text-gray-500">{{ olderPost.date | date: '%-d %b %Y' }}</p>
                {% if olderPost.data.summary %}
                    <p class="text-sm text-gray-400">{{ olderPost.data.summary | truncate: 100 }}</p>
                    {% elsif olderPost.data.title == nil %}
                    <p class="text-sm text-gray-400">{{ olderPost.content | strip_html | truncate: 100 }}</p>
                {% endif %}
            </a>
        {% else %}
            <span></span>
        {% endif %}
    </nav>
{% endif %}
