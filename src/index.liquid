---
title: Sean Peters
layout: default.liquid
pagination:
    data: collections.posts
    size: 15
    reverse: true
permalink: "{% if pagination.pageNumber == 0 %}/{% else %}/more-posts/{{ pagination.pageNumber }}/{% endif %}"
---

{% for post in pagination.items %}
    <article class="py-10">
        <h2 class="mb-2 text-3xl font-bold">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        <p class="mb-4 text-sm text-gray-400">
            <a href="{{ post.url }}">{{ post.date | date: '%-d %b %Y' }}</a>
        </p>
        {% if post.data.summary %}<p class="tracking-wide leading-relaxed">{{ post.data.summary }}</p>{% endif %}
    </article>
    {% unless forloop.last %}
    <hr class="border-gray-600">
{% endunless %}
{% endfor %}
{% render "partials/pagination.liquid", pagination: pagination %}
